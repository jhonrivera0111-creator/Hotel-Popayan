<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <!-- ICONO CHECK -->
        <TextView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="#A5D6A7"
            android:gravity="center"
            android:text="✓"
            android:textSize="40sp"
            android:textColor="#000"
            android:layout_marginTop="24dp" />

        <!-- TITULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¡Reserva Exitosa!"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <!-- DESCRIPCION -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tu estancia en Popayán está confirmada. Hemos enviado un correo con los detalles."
            android:textSize="14sp"
            android:textColor="#888"
            android:gravity="center"
            android:layout_marginTop="8dp" />

        <!-- CARD -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginTop="20dp"
            android:elevation="4dp">

            <!-- LINEA VERDE -->
            <View
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:background="#2ECC71"
                android:layout_marginBottom="12dp"/>

            <!-- FECHAS -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:text="Entrada"
                        android:textColor="#888"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="05 Mar"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">

                    <TextView
                        android:text="Salida"
                        android:textColor="#888"
                        android:textSize="12sp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>

                    <TextView
                        android:text="07 Mar"
                        android:textStyle="bold"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </LinearLayout>

            <!-- SEPARADOR -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#EEEEEE"
                android:layout_marginVertical="12dp"/>

            <!-- HABITACION -->
            <TextView
                android:text="Habitación"
                android:textColor="#888"
                android:textSize="12sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:text="Suite Colonial"
                android:textStyle="bold"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- ID -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:text="ID Reserva"
                    android:textColor="#888"
                    android:textSize="12sp"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="#FFF3E0"
                    android:padding="6dp"
                    android:text="#APP-2026"
                    android:textColor="#D35400"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- BOTON PRINCIPAL -->
        <Button
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:layout_marginTop="24dp"
            android:backgroundTint="#D35400"
            android:text="Ver Comprobante"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />

        <!-- VOLVER -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Volver al Inicio"
            android:textSize="14sp"
            android:layout_marginTop="12dp" />

    </LinearLayout>

</ScrollView>